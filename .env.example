NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
APP_URL=http://localhost:3000
CLIENT_PORTAL_SECRET=

# Gallery notification email delivery (optional, required for publish-time sends)
# Option A: Resend API
RESEND_API_KEY=
GALLERY_NOTIFICATIONS_FROM_EMAIL=
GALLERY_NOTIFICATIONS_REPLY_TO=
# Display name shown as the email sender (defaults to "Six Stories Studio")
GALLERY_NOTIFICATIONS_FROM_NAME=Six Stories Studio

# Option B: Your own SMTP server (takes priority when SMTP_HOST is set)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Cloudflare R2 storage (optional — falls back to Supabase Storage if unset)
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=sixstories
# Optional: public base URL for the R2 bucket (e.g. https://media.sixstoriesstudio.com)
CLOUDFLARE_R2_PUBLIC_URL=
